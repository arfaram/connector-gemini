{
    "name": "arfaram/connector-gemini",
    "description": "Google Gemini AI connector for Ibexa DXP",
    "license": "MIT",
    "type": "ibexa-bundle",
    "keywords": [
        "ibexa-dxp",
        "ibexa",
        "gemini",
        "AI"
    ],
    "authors": [
        {
            "name": "Ramzi Arfaoui",
            "email": "ramzi_arfa@hotmail.de"
        }
    ],
    "version": "1.0.0",
    "require": {
        "php": ">=8.3",
        "ibexa/connector-ai": "~5.0",
        "ibexa/core": "~5.0",
        "symfony/config": "^7.3",
        "symfony/dependency-injection": "^7.3",
        "symfony/http-client": "^7.3",
        "symfony/http-kernel": "^7.3",
        "symfony/yaml": "^7.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "ConnectorGeminiBundle\\": "src/bundle/",
            "ConnectorGemini\\Contracts\\": "src/contracts/",
            "ConnectorGemini\\": "src/lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ConnectorGemini\\Tests\\Bundle\\": "tests/bundle/",
            "ConnectorGemini\\Tests\\Integration\\": "tests/integration/",
            "ConnectorGemini\\Tests\\Lib\\": "tests/lib/"
        }
    }
}



